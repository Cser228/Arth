mem 398 + 1 .

0 while dup 398 < do
	0 while dup 400 < do
		dup mem + , if
			mem 400 + 42 .
		else
			mem 400 + 32 .
		end
		1 mem 400 + 1 3 1 syscall

		1 +
	end
	drop

	mem 400 + 10 .
	1 mem 400 + 1 3 1 syscall

	//pattern
	mem , 1 shl
	mem 1 + ,
	bor

	1 while dup 398 < do
		swap 1 shl 7 band
		over mem + 1 + , bor
	
		2dup 110 swap shr 1 band
		swap mem + swap .
		swap

		1 +
	end
	drop drop

	1 +
end
drop
