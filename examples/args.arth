include "io.arth"

//Method with instructions `argc` and `argv`

argv argc
"Argc: " writef drop
dup dump
"Argv: " writef drop

while dup 0 > do
	"\n\t" writef drop
	over ,64 dup strlen writef drop

	1 - swap 8 + swap
end drop drop


"\n\n" writef drop


//Method with stack

"Argc: " writef drop
dump
"Argv: " writef drop

while dup 0 > do
	"\n\t" writef drop
	dup strlen writef drop
end
"\n" writef drop
