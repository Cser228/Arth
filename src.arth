include "io.arth"

macro answer mem end

100 while dup 1000 < do
	100 while dup 1000 < do
		2dup *

		dup 0 while over 0 > do
			10 * over 10 % + swap 10 / swap
		end
		swap drop

		2dup = if
			dup answer ,64 > if
				answer over .64
			end
		end
		drop drop

		1 +
	end drop

	1 +
end drop

answer ,64 dump
